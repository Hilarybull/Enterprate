# Enterprate OS - Environment Variables Example
# Copy this file to .env and update with your values

# Backend Configuration
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/
DB_NAME=enterprate_os
CORS_ORIGINS=*

# Security
JWT_SECRET=anyrandomlongstring123456789

# AI Integration (Optional - for future AI features)
EMERGENT_LLM_KEY=your-emergent-llm-key
GEMINI_API_KEY=your-gemini-api-key

# DataForSEO (Optional - for live keyword intelligence in validation reports)
DATAFORSEO_LOGIN=your-dataforseo-login-email
DATAFORSEO_PASSWORD=your-dataforseo-api-password

# Community Signals (Optional - live sources)
YOUTUBE_API_KEY=your-youtube-data-api-key
FACEBOOK_GRAPH_TOKEN=your-facebook-graph-access-token
BING_SEARCH_API_KEY=your-bing-search-v7-key

# OAuth (Optional - for Google authentication)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# URLs
FRONTEND_URL=http://localhost:3000
