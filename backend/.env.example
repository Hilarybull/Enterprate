# ============================================
# Enterprate OS - Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control
# ============================================

# ============================================
# REQUIRED - Database
# ============================================
# MongoDB connection string
# For MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/
# For local: mongodb://localhost:27017/
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/

# Database name
DB_NAME=enterprate

# ============================================
# REQUIRED - Security
# ============================================
# JWT secret for authentication (min 32 characters)
# Generate with: openssl rand -hex 32
JWT_SECRET=anyrandomlongstring123456789

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3000

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# ============================================
# REQUIRED - AI Integration
# ============================================
# Claude API key (preferred for assistant/chat)
# Get from: https://console.anthropic.com/
CLAUDE_API_KEY=

# Gemini API key (optional fallback)
GEMINI_API_KEY=

# Emergent LLM Key for AI features
# Get from: Emergent Platform
EMERGENT_LLM_KEY=sk-emergent-your-key-here

# ============================================
# OPTIONAL - Companies House API (UK Company Data)
# ============================================
# Get from: https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY=

# ============================================
# OPTIONAL - Email (SendGrid)
# ============================================
# Get from: https://sendgrid.com/
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ============================================
# OPTIONAL - Google OAuth
# ============================================
# Get from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# OPTIONAL - Social Media Integrations
# ============================================

# Twitter/X API
# Get from: https://developer.twitter.com/
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=

# Facebook/Instagram
# Get from: https://developers.facebook.com/
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# LinkedIn
# Get from: https://www.linkedin.com/developers/
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=

# YouTube
# Get from: https://console.cloud.google.com/
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
